{
  "name": "codexia",
  "version": "0.5.1",
  "description": "Engineering intelligence layer for repositories - analyze impact, complexity, history, and enforce architectural invariants",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codexia": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:dashboard",
    "build:cli": "tsc",
    "build:dashboard": "cd src/dashboard/client && npm install && npm run build",
    "start": "node dist/cli/index.js",
    "dev": "tsc --watch",
    "dev:dashboard": "npm run build:cli && node dist/cli/index.js dashboard --repo . --open",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "security:deps": "npm audit --audit-level=high",
    "security:check": "npm run lint && npm test && npm run security:deps",
    "clean": "rm -rf dist",
    "mcp": "node dist/mcp/server.js",
    "dashboard": "node dist/cli/index.js dashboard --open"
  },
  "keywords": [
    "code-analysis",
    "engineering-intelligence",
    "git",
    "impact-analysis",
    "developer-tools",
    "complexity",
    "monorepo",
    "architectural-invariants",
    "mcp",
    "ai-tools",
    "changelog",
    "dependency-graph"
  ],
  "author": "Seshan Pillay",
  "license": "AGPL-3.0",
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^10.3.10",
    "gradient-string": "^3.0.0",
    "kuzu": "^0.11.3",
    "ora": "^8.1.1",
    "simple-git": "^3.22.0",
    "tree-sitter": "^0.22.4",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-go": "^0.21.2",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "ts-morph": "^21.0.1",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.17"
  },
  "files": [
    "dist/ai",
    "dist/cli",
    "dist/codegraph",
    "dist/core",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/learning",
    "dist/mcp",
    "dist/modules",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seshxn/codexia.git"
  },
  "bugs": {
    "url": "https://github.com/seshxn/codexia/issues"
  },
  "homepage": "https://github.com/seshxn/codexia#readme"
}
