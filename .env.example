# =============================================================================
# Codexia Environment Example
# Copy to .env and fill only what you need.
# Core CLI commands work without any env vars.
# =============================================================================

# -----------------------------------------------------------------------------
# Common Dashboard Setup
# -----------------------------------------------------------------------------
# Dashboard server binding.
CODEXIA_DASHBOARD_HOST=127.0.0.1

# Optional bearer token for the dashboard API.
CODEXIA_DASHBOARD_TOKEN=

# Optional team mapping setup for multi-repo engineering intelligence.
# Single-repo GitHub stats can work without this when the current repo has a GitHub remote.
# Use a JSON array or { "teams": [...] } object.
# Legacy fallback: codexia.teams.yaml in the repo root still works.
CODEXIA_DASHBOARD_TEAMS_JSON=
# Example:
# CODEXIA_DASHBOARD_TEAMS_JSON='{"teams":[{"name":"Platform","repos":["acme/api","acme/web"],"github":{"org":"acme","team":"platform"},"jira":{"boardIds":[12],"projectKeys":["PLAT"]},"deployments":{"environments":["production"],"branches":["main"]},"incidents":{"projectKeys":["OPS"],"issueTypes":["Incident"]}}]}'

# GitHub analytics for the engineering dashboard.
CODEXIA_GITHUB_TOKEN=

# Jira analytics for the engineering dashboard.
CODEXIA_JIRA_BASE_URL=
# Use either basic auth:
CODEXIA_JIRA_EMAIL=
CODEXIA_JIRA_API_TOKEN=
# Or bearer auth:
CODEXIA_JIRA_BEARER_TOKEN=

# -----------------------------------------------------------------------------
# Common AI Setup
# -----------------------------------------------------------------------------
# Supported providers: openai, anthropic, ollama, gemini, bedrock
CODEXIA_AI_PROVIDER=

# Required for openai / anthropic / gemini. Not needed for ollama.
CODEXIA_AI_API_KEY=

# Optional overrides.
CODEXIA_AI_MODEL=
CODEXIA_AI_BASE_URL=

# -----------------------------------------------------------------------------
# Common MCP / HTTP Setup
# -----------------------------------------------------------------------------
CODEXIA_MCP_HOST=127.0.0.1
CODEXIA_MCP_TOKEN=

# -----------------------------------------------------------------------------
# Advanced Optional Settings
# -----------------------------------------------------------------------------
# Skip automatic .env.local / .env loading.
CODEXIA_SKIP_ENV_FILE=false

# Repo index cache staleness in milliseconds (default: 1 hour).
CODEXIA_CACHE_STALENESS_MS=3600000

# Extra temporal analyzer logs.
DEBUG_TEMPORAL_ANALYZER=false

# Dashboard CORS allowlist.
# Example: http://localhost:3200,http://127.0.0.1:3200
CODEXIA_DASHBOARD_ALLOWED_ORIGINS=

# Dashboard API rate limiting.
CODEXIA_DASHBOARD_RATE_LIMIT_WINDOW_MS=60000
CODEXIA_DASHBOARD_RATE_LIMIT_MAX=120

# GitHub Enterprise or API proxy override.
CODEXIA_GITHUB_API_URL=https://api.github.com

# Jira throttling and time budgets.
CODEXIA_JIRA_RETRY_MAX=1
CODEXIA_JIRA_RETRY_BASE_MS=500
CODEXIA_JIRA_RETRY_MAX_MS=4000
CODEXIA_JIRA_REQUEST_TIMEOUT_MS=15000
CODEXIA_JIRA_MAX_ISSUES_PER_SPRINT=500
CODEXIA_JIRA_SPRINT_SEARCH_TIME_BUDGET_MS=15000
# Sprint membership strategy:
# - current_only (default, fastest, no historical WAS/CHANGED lookups)
# - auto (attempt historical membership via JQL WAS/CHANGED)
CODEXIA_JIRA_SPRINT_MEMBERSHIP_MODE=current_only
CODEXIA_JIRA_CACHE_TTL_MS=90000
CODEXIA_JIRA_BOARD_TIME_BUDGET_MS=45000

# Bedrock credentials (required when CODEXIA_AI_PROVIDER=bedrock).
CODEXIA_AI_AWS_REGION=
CODEXIA_AI_AWS_ACCESS_KEY_ID=
CODEXIA_AI_AWS_SECRET_ACCESS_KEY=
CODEXIA_AI_AWS_SESSION_TOKEN=

# Optional fallback AWS env vars also read by the app:
# AWS_REGION=
# AWS_DEFAULT_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# MCP HTTP server safeguards.
CODEXIA_MCP_MAX_BODY_BYTES=1048576
CODEXIA_MCP_RATE_LIMIT_WINDOW_MS=60000
CODEXIA_MCP_RATE_LIMIT_MAX=120
